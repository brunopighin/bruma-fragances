# Las fotos subidas se sirven normalmente, pero nunca se ejecutan como PHP.
<FilesMatch "\.(php|phtml|php[0-9]|pht)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
